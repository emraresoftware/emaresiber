PORT=8125
# ============================================================
# SiberEmare Multi-Agent Orchestrator — .env.example
# Kopyala: cp .env.example .env  ve değerleri doldur
# ============================================================

# ---- LLM Backend ----
# Seçenekler: cloud | onprem | hybrid
LLM_MODE=cloud

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings + GPT-4o vision fallback)
OPENAI_API_KEY=sk-...

# Vision/Multimodal model
VISION_MODEL=gpt-4o

# Groq (hybrid fast tasks)
GROQ_API_KEY=gsk_...

# On-Prem Ollama
OLLAMA_MODEL=llama3.3:70b
OLLAMA_URL=http://localhost:11434

# ---- Graph Backend ----
GRAPH_MODE=neo4j_local        # neo4j_local | networkx_fallback
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
GDS_ENABLED=true
VECTOR_INDEX_DIM=3072

# PGVector
PGVECTOR_URL=postgresql://user:pass@localhost:5432/pentest
PGVECTOR_MODE=hnsw             # hnsw | ivfflat | faiss_fallback

# Redis Cache
GRAPH_CACHE=redis://localhost:6379

# ---- Slack Integration ----
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#pentest-approvals

# ---- Jira Integration ----
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=your@email.com
JIRA_API_TOKEN=ATATT...
JIRA_PROJECT=SEC
